# Revalidation API認証用シークレット
# microCMSのWebhookからキャッシュクリアAPIを呼び出す際に使用
REVALIDATE_SECRET=

# microCMS設定
# サービスドメイン（例: your-service.microcms.io）
MICROCMS_SERVICE_DOMAIN=
# APIキー（Read API Key）
MICROCMS_API_KEY=

# SMTP設定（メール送信用）
# SMTPサーバーのホスト（例: smtp.gmail.com）
SMTP_HOST=
# SMTPサーバーのポート（例: 587）
SMTP_PORT=
# SMTP認証用のユーザー名（メールアドレス）
SMTP_USER=
# SMTP認証用のパスワード（アプリパスワード）
SMTP_PASS=

# メール設定（SMTP_USER/SMTP_PASSの代替として使用可能）
# メール送信用のユーザー名
EMAIL_USER=
# メール送信用のパスワード
EMAIL_PASSWORD=

# お問い合わせフォームの送信先メールアドレス
RECIPIENT_EMAIL=
